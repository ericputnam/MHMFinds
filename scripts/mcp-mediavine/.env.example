# Copy to .env.local (gitignored) and fill in. NEVER commit the real token.
#
# MEDIAVINE_JWT: the Bearer token the dashboard SPA uses.
#   How to grab it:
#     1. Log in to https://reporting.mediavine.com (Google sign-in).
#     2. Open DevTools → Application → Local Storage → reporting.mediavine.com.
#     3. Copy the "jwt" value out of the "dashboard" entry.
#   This token EXPIRES — see README.md "Refreshing the token".
MEDIAVINE_JWT=eyJhbG...your-token-here...

# Site id (14318 = MustHaveMods). Override only for a different site.
MEDIAVINE_SITE_ID=14318
