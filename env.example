# Database
DATABASE_URL="postgresql://username:password@localhost:5432/modvault"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# OpenAI API (for AI features)
OPENAI_API_KEY="your-openai-api-key"

# Vector Database (Pinecone)
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_ENVIRONMENT="your-pinecone-environment"
PINECONE_INDEX_NAME="modvault-embeddings"

# Content Source APIs
PATREON_CLIENT_ID="your-patreon-client-id"
PATREON_CLIENT_SECRET="your-patreon-client-secret"
CURSEFORGE_API_KEY="your-curseforge-api-key"

# Privacy Settings for Content Aggregation
PRIVACY_LEVEL="default" # Options: default, stealth, conservative

# Redis (for caching and sessions)
REDIS_URL="redis://localhost:6379"

# Elasticsearch (for full-text search)
ELASTICSEARCH_URL="http://localhost:9200"

# File Storage (AWS S3 or similar)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="modvault-assets"

# Email Service (SendGrid, AWS SES, etc.)
SENDGRID_API_KEY="your-sendgrid-api-key"
FROM_EMAIL="noreply@modvault.com"

# Analytics
GOOGLE_ANALYTICS_ID="your-ga-id"
MIXPANEL_TOKEN="your-mixpanel-token"

# Monitoring
SENTRY_DSN="your-sentry-dsn"

# Development
NODE_ENV="development"
DEBUG="modvault:*"

# Affiliate Network Reporting APIs (commission/conversion ingestion)
# Impact.com: dashboard -> Settings -> API (publisher account 2956236)
IMPACT_ACCOUNT_SID="your-impact-account-sid"
IMPACT_AUTH_TOKEN="your-impact-auth-token"
# Rakuten Advertising: developer portal -> application Client ID/Secret + publisher Site ID
RAKUTEN_CLIENT_ID="your-rakuten-client-id"
RAKUTEN_CLIENT_SECRET="your-rakuten-client-secret"
RAKUTEN_SID="your-rakuten-publisher-sid"
# CJ Affiliate: developers.cj.com -> Authentication -> Personal Access Tokens
CJ_PERSONAL_ACCESS_TOKEN="your-cj-personal-access-token"
CJ_PUBLISHER_ID="your-cj-publisher-id"
# Note: Amazon Associates has no earnings API - import the earnings CSV via the
# admin dashboard (/admin/monetization/affiliates -> Amazon CSV)

# Cron authentication (Vercel cron jobs send this as a Bearer token)
CRON_SECRET="your-cron-secret"
